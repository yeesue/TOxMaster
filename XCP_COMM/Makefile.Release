D:/lyx/code/TOxMaster/XCP_COMM/build/obj/TCM_resource_res.o: TCM_resource.rc
	windres -i TCM_resource.rc -o D:\lyx\code\TOxMaster\XCP_COMM\build\obj\TCM_resource_res.o --include-dir=. $(DEFINES)

qmake: FORCE
	@$(QMAKE) -o Makefile.Release XCP_COMM.pro -spec win32-g++ "CONFIG+=release"

qmake_all: FORCE

