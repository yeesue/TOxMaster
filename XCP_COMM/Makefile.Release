####### Build rules

first: all
all: Makefile.Release  $(DESTDIR_TARGET)

$(DESTDIR_TARGET): D:/Qt/Qt5.9.9/5.9.9/mingw53_32/lib/libQt5AxContainer.a D:/Qt/Qt5.9.9/5.9.9/mingw53_32/lib/libQt5AxBase.a build/ui/ui_workspacewin.h build/ui/ui_functionwin.h build/ui/ui_rcdsetdlg.h build/ui/ui_logwin.h build/ui/ui_funpamdlg.h build/ui/ui_pamfactorywin.h build/ui/ui_pamlistdlg.h build/ui/ui_pamseldlg.h build/ui/ui_cansetdlg.h build/ui/ui_tscansetdlg.h build/ui/ui_zlgcansetdlg.h build/ui/ui_a2lprojectwin.h build/ui/ui_mapwin.h build/ui/ui_xcpsetdlg.h build/ui/ui_calmanagewin.h build/ui/ui_configwin.h build/ui/ui_mainwindow.h build/ui/ui_settingwin.h build/ui/ui_scriptwin.h build/ui/ui_verifydialog.h build/ui/ui_csv_win.h build/ui/ui_csvsettingdlg.h build/ui/ui_pampropdlg.h build/ui/ui_tablewin.h build/ui/ui_StatusDialog.h build/ui/ui_dockwindow.h build/ui/ui_win_wt5000.h build/ui/ui_wt5000setdlg.h build/ui/ui_win_wt3000.h build/ui/ui_wt3000setdlg.h build/ui/ui_auto_win.h build/ui/ui_autoexewin.h build/ui/ui_cmd_dlg.h $(OBJECTS) D:/lyx/code/TOxMaster/XCP_COMM/build/obj/TCM_resource_res.o
