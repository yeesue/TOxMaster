    }
    QGroupBox {
        border: 1px solid #d1d5db;
        border-radius: 8px;
        margin-top: 1.5ex;
        font: 14px &quot;Microsoft YaHei&quot;;
        color: #1f2937;
        padding-top: 12px;
    }
    QGroupBox::title {
        subcontrol-origin: margin;
        left: 12px;
        padding: 0 4px;
        color: #3b82f6;
    }
    QPushButton {
        background: #3b82f6;
        color: white;
        border: none;
        border-radius: 3px;
        padding: 2px 4px;
        font: 14px &quot;Microsoft YaHei&quot;;
        min-width: 30px;
    }
    QPushButton:hover {
        background: #2563eb;
    }
    QPushButton:pressed {
        background: #1d4ed8;
    }
    QLineEdit, QSpinBox, QComboBox, QTextEdit {
        border: 1px solid #d1d5db;
        border-radius: 6px;
        padding: 3px;
        background: white;
        selection-background-color: #bfdbfe;
        font: 14px &quot;Microsoft YaHei&quot;;
    }
    QListWidget, QTreeWidget, QTableWidget {
        border: 1px solid #d1d5db;
        border-radius: 3px;
        background: white;
        alternate-background-color: #f3f4f6;
    }
    QHeaderView::section {
        background: #e5e7eb;
        color: #374151;
        padding: 3px;
        border: none;
        font: bold 14px &quot;Microsoft YaHei&quot;;
    }
    QProgressBar {
        border: 1px solid #d1d5db;
        border-radius: 6px;
        background: white;
        text-align: center;
    }
    QProgressBar::chunk {
        background: #3b82f6;
        border-radius: 4px;
    }
    QLabel {
        color: #374151;
        font: 14px &quot;Microsoft YaHei&quot;;
    }
    QLine {
        background: #d1d5db;
    }
    QCheckBox {
        spacing: 6px;
        font: 14px &quot;Microsoft YaHei&quot;;
    }
    QCheckBox::indicator {
        width: 18px;
        height: 18px;
        border: 2px solid #d1d5db;
        border-radius: 4px;
    }
    QCheckBox::indicator:checked {
        background: #3b82f6;
        border-color: #3b82f6;
    }
    QDoubleSpinBox::up-button, QDoubleSpin</string>
