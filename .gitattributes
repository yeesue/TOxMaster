# Auto detect text files and normalize line endings to LF
* text=auto

# Binary files - don't touch them
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.bmp binary
*.pdf binary
*.zip binary
*.7z binary
*.exe binary
*.dll binary
*.lib binary
*.a binary
*.so binary
*.dylib binary
*.qch binary
*.qch.bak binary

# Source code files - normalize to LF
*.cpp text eol=lf
*.h text eol=lf
*.c text eol=lf
*.hpp text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.qrc text eol=lf
*.pro text eol=lf
*.pri text eol=lf
*.ui text eol=lf
