---
# TOxMaster 项目代码格式化配置

# 基本设置
BasedOnStyle: Google
IndentWidth: 4
TabWidth: 4
UseTab: Never

# 大括号样式
BreakBeforeBraces: Attach

# 行长度
ColumnLimit: 100

# 空格设置
SpaceBeforeAssignmentOperators: true

# 换行设置
BreakBeforeBinaryOperators: All

# C++ 特有设置
Cpp11BracedListStyle: true
PointerAlignment: Left
