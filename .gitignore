# ===========================================
# TOxMaster Project .gitignore
# ===========================================

# -------------------------------------------
# 编译产物
# -------------------------------------------
build/
obj/
x64/
x86/
debug/
release/
*.exe
*.dll
*.so
*.dylib
*.a
*.lib
*.o
*.obj
*.pdb
*.ilk
*.exp
*.idb
*.ipch
*.tlog
*.lastbuildstate
*.unsuccessfulbuild
*.cache

# -------------------------------------------
# Qt相关
# -------------------------------------------
moc_*.cpp
moc_*.h
qrc_*.cpp
ui_*.h
*.qm
rcc/

# -------------------------------------------
# IDE和编辑器
# -------------------------------------------
# Visual Studio
.vs/
*.suo
*.user
*.sln.docstates
*.sln
*.vcxproj*
*.psess
*.vsp
*.vspx

# Qt Creator
*.pro.user
*.pro.user.*
.qmake.stash

# VSCode
.vscode/

# JetBrains
.idea/

# -------------------------------------------
# 第三方工具 (项目特定)
# -------------------------------------------
notepad++/
Hunspell/

# -------------------------------------------
# 大型测试数据文件
# -------------------------------------------
# A2L文件 (通常很大)
*.a2l
# Hex/S19文件
*.hex
*.s19
*.srec
# MDF/测量数据文件
*.mdf
*.mf4
*.dat
# 日志文件
*.log
build_*.log

# -------------------------------------------
# 临时文件和备份
# -------------------------------------------
*.tmp
*.temp
*.bak
*.backup
*~
*.swp
*.swo
backup/
temp/
tmp/

# -------------------------------------------
# 系统文件
# -------------------------------------------
# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride

# -------------------------------------------
# 敏感信息和配置
# -------------------------------------------
# 包含密钥/密码的配置文件
*secret*
*password*
*key*.pem
*credential*
*.pfx
*.p12

# -------------------------------------------
# 依赖和外部库
# -------------------------------------------
# 如果是外部下载的库，排除
# lib/external/
# 如果是项目自己编译的库，保留
# *.lib

# -------------------------------------------
# 其他
# -------------------------------------------
# ZIP压缩包
*.zip
*.rar
*.7z
*.tar.gz

# 编码问题产生的损坏文件备份
*_corrupted/
*.orig

# Codebuddy数据 (AI工具数据，不应提交)
.codebuddy/
